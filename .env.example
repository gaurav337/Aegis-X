AEGIS_MODEL_DIR=models/
AEGIS_DEVICE=auto
OLLAMA_ENDPOINT=http://localhost:11434
LOG_LEVEL=INFO
# .env
AEGIS_VRAM_THRESHOLD=3.5
# =============================================================================
# OLLAMA CONFIGURATION (Day 18 - FINAL v7)
# =============================================================================

OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_TIMEOUT=120

# C1: Omit for Ollama default (5min) - optimal for batch scanning
# 0 = immediate unload (4× slower on batch)
# -1 = keep forever (VRAM exhaustion)
# (empty) = Ollama default 5min ✓
OLLAMA_KEEP_ALIVE=

# Generation settings
LLM_TEMPERATURE=0.1
LLM_SEED=42
LLM_MAX_TOKENS=1024
LLM_CONTEXT_WINDOW=4096

# Retry settings
AGENT_MAX_RETRIES=2
AGENT_LLM_TIMEOUT=120